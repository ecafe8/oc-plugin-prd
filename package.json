{
  "name": "oc-plugin-prd",
  "module": "dist/index.js",
  "main": "dist/index.js",
  "types": "src/index.ts",
  "type": "module",
  "private": true,
  "scripts": {
    "build": "bun build src/index.ts --outdir dist --target bun",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "bun run check && bun run build",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "format": "biome format --write .",
    "lint": "biome lint .",
    "lint:biome": "biome lint .",
    "check": "biome check . && bun run typecheck && bun test",
    "clean": "rm -rf dist coverage"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.1",
    "@types/bun": "latest",
    "bun-types": "^1.3.14",
    "lefthook": "^2.1.9"
  },
  "peerDependencies": {
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "@opencode-ai/plugin": "^1.17.10",
    "@opencode-ai/sdk": "^1.17.10",
    "jsonc-parser": "^3.3.1",
    "yaml": "^2.9.0",
    "zod": "^4.1.5"
  }
}
